---
import LinkedinLogo from "@/assets/linkedin.svg";
import GithubLogo from "@/assets/github.svg";

const navItems = [
	{ title: "Home", path: "/" },
	{ title: "About", path: "/about" },
	{ title: "Posts", path: "/posts" },
];
---

<style>
    @media (min-width: 48em) {
        .sidebar {
            height: calc(100% - 4em);
            width: 16em;
            padding: 2em;
            font-size: 0.7rem;
        }
    }
    @media (min-width: 72em) {
        .sidebar {
            font-size: 1rem;
        }
    }
    .sidebar {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        color: #9a9a9a;
        background-color: #181818;
    }

    .sidebar a {
        color: #ddd;
        text-decoration: none;
    }

    .sidebar a:hover {
        color: #fff;
    }

    .title a {
        color: #ddd;
        text-decoration: underline purple 0.3em;
        text-underline-offset: 0.2em;
    }

    .title h1 {
        font-size: 3em;
        margin-bottom: 0.5rem;
    }

    .about {
        font-size: 1.15em;
        line-height: 1.8;
        font-weight: 300;
        color: #bbb;
    }

    .about hr {
        margin: 0.7rem 0;
        position: relative;
        border: 0;
        border-top: 0.2em solid purple;
    }

    .nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.2em;
        font-size: 0.65em;
    }
    .nav a {
        display: inline-flex;
        align-items: center;
    }
    .logo {
        opacity: 70%;
    }
    .logo:hover {
        opacity: 100%;
    }
    .nav-item-active {
        font-weight: 700;
    }
</style>
<div class="sidebar">
    <div class="title">
        <a href="/"><h1>yonathan <br />gashu</h1></a>
    </div>
    <div class="about">
        <p>
            i like computers and cats and games and music and drawing and
            snowboaridn gand skateboaridng and i like to play bass and guitar
            too!
        </p>
        <hr />
        <nav class="nav">
            {
                navItems.map(({ title, path }) => (
                    <>
                        <a
                            href={path}
                            class:list={{
                                ["nav-item-active"]:
                                    Astro.url.pathname === path,
                            }}
                        >
                            {title}
                        </a>
                        ✦
                    </>
                ))
            }

            <a href="https://yonathangashu.github.io/resume/resume.pdf"
                >Resume</a
            >
            ✦
            <a href="https://github.com/YonathanGashu"
                ><GithubLogo class="logo" width="1.25em" height="auto" /></a
            >
            ✦
            <a href="https://linkedin.com/in/ygashu"
                ><LinkedinLogo class="logo" width="1.25em" height="auto" /></a
            >
        </nav>
    </div>
</div>
