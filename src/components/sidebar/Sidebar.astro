---
import GithubLogo from "@/assets/github.svg";
import LinkedinLogo from "@/assets/linkedin.svg";
import Footer from "@/components/footer/Footer.astro";

const navItems = [
	{ title: "About", path: "/" },
	{ title: "Posts", path: "/posts/" },
];
---

<style>
    .sidebar {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
        color: #9a9a9a;
        background-color: #130920;
        width: 100%;
        height: auto;
    }
    .sidebar-content {
        display: contents;
    }

    .title h1 {
        font-size: 1.8rem;
        margin: 0;
        margin-bottom: 0.5rem;
        line-height: 1.1;
    }

    .title h1 br {
        display: none;
    }

    .about p {
        display: none;
    }

    .about hr {
        display: none;
    }

    .nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.6rem;
    }
    .footer-wrapper {
        display: none;
    }
    @media (min-width: 48rem) {
        .sidebar {
            flex-direction: column;
            justify-content: space-between;
            width: 14rem;
            height: 100%;
            padding: 1.5rem;
            font-size: 0.7rem;
        }
        .sidebar-content {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
        }

        .title h1 {
            font-size: 2.2rem;
        }

        .title h1 br {
            display: block;
        }

        .about p {
            display: block;
        }

        .about hr {
            display: block;
            margin: 0.7rem 0;
            position: relative;
            border: 0;
            border-top: 0.2rem solid #682f8e;
        }

        .about {
            font-size: 0.9rem;
        }

        .nav {
            font-size: 0.55rem;
            gap: 0.1rem;
        }

        .logo {
            width: 12px;
        }
        .footer-wrapper {
            display: block;
            margin-top: auto;
        }
    }

    @media (min-width: 72rem) {
        .sidebar {
            width: 18rem;
            padding: 2rem;
            font-size: 1rem;
        }

        .title h1 {
            font-size: 3rem;
            margin-bottom: 0.5rem;
        }

        .about {
            font-size: 1.15rem;
        }

        .nav {
            font-size: 0.75rem;
            gap: 0.2rem;
        }
    }

    .sidebar a {
        color: #ddd;
        text-decoration: none;
    }

    .sidebar a:hover {
        color: #fff;
    }

    .title a {
        color: #ddd;
        text-decoration: underline #682f8e 0.3rem;
        text-underline-offset: 0.2rem;
    }

    .about {
        line-height: 1.6;
        font-weight: 300;
        color: #bbb;
    }

    .nav a {
        display: inline-flex;
        align-items: center;
    }

    .logo {
        opacity: 70%;
    }

    .logo:hover {
        opacity: 100%;
    }

    .nav-item-active {
        font-weight: 700;
    }
</style>
<div class="sidebar">
    <div class="sidebar-content">
        <div class="title">
            <a href="/"><h1>yonathan <br />gashu</h1></a>
        </div>
        <div class="about">
            <p>
                security engineer working in binary exploitation and reverse
                engineering
            </p>
            <hr />
            <nav class="nav">
                <a href="/">Home</a>✦

                {
                    navItems.map(({ title, path }) => (
                        <>
                            <a
                                href={path}
                                class:list={{
                                    ["nav-item-active"]:
                                        Astro.url.pathname === path,
                                }}
                            >
                                {title}
                            </a>
                            ✦
                        </>
                    ))
                }

                <a href="https://yonathangashu.github.io/resume/resume.pdf"
                    >Resume</a
                >
                ✦
                <a href="https://github.com/YonathanGashu"
                    ><GithubLogo class="logo" width="1rem" height="auto" /></a
                >
                ✦
                <a href="https://linkedin.com/in/ygashu"
                    ><LinkedinLogo
                        class="logo"
                        width=".9rem"
                        height="auto"
                    /></a
                >
            </nav>
        </div>
    </div>
</div>
